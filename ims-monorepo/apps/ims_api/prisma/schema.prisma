// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {   // Example model - replace with your actual models
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
}


model TestTable {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
}